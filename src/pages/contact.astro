---
import Layout from '../layouts/Layout.astro';
import ThreeScene from '../components/ThreeScene.tsx';
import ParticleField from '../components/ParticleField.tsx';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Qignite',
  url: 'https://qignite.com/contact',
  description: 'Get in touch with Qignite for AI-powered QA solutions and consulting.',
};
---

<Layout
  title="Contact Qignite — Let's Talk Quality"
  description="Ready to elevate your software quality with AI? Reach out to Qignite for QA engineering, test automation, and AI support solutions tailored to your needs."
  keywords="contact Qignite, QA consultation, hire QA engineers, AI testing consulting, software quality services Pakistan"
  structuredData={pageSchema}
>
  <section class="page-hero section has-3d" aria-labelledby="contact-heading">
    <ThreeScene client:visible />
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="container rel">
      <span class="section-tag reveal-3d-scale" style="transition-delay:0s">Get in Touch</span>
      <h1 class="contact-hero-heading reveal-3d" id="contact-heading" style="transition-delay:0.1s">
        Let's Talk <span class="text-accent">Quality.</span>
      </h1>
      <p class="page-sub reveal-3d" style="transition-delay:0.2s">
        Whether you need AI-powered QA, healthcare testing expertise, or enterprise quality engineering. We're ready to help. Reach out and let's start the conversation.
      </p>
    </div>
  </section>

  <section class="section contact-section has-3d parallax-section" aria-labelledby="contact-info-heading" data-parallax="0.03">
    <ParticleField client:visible count={120} opacity={0.3} />
    <div class="section-3d-overlay" aria-hidden="true"></div>
    <div class="container rel">
      <div class="contact-grid">

        <!-- SIDEBAR -->
        <aside class="contact-info reveal-3d-left" style="transition-delay:0s" aria-label="Contact information">
          <div class="info-block card" data-tilt-contact>
            <h3>Connect Directly</h3>
            <a href="mailto:qigniteops@gmail.com" class="info-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
              qigniteops@gmail.com
            </a>
            <a href="https://www.linkedin.com/company/qignite/" target="_blank" rel="noopener noreferrer" class="info-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn Qignite
            </a>
            <a href="https://www.upwork.com/freelancers/umairnadeemqa?mp_source=share" target="_blank" rel="noopener noreferrer" class="info-link upwork-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.546-1.405 0-2.543-1.14-2.545-2.546V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
              </svg>
              Hire on Upwork
            </a>
          </div>

          <div class="info-block card" data-tilt-contact>
            <h3>Our Services</h3>
            <ul class="info-services">
              {['AI QA Automation', 'Healthcare Platform QA', 'AI Customer Support', 'Enterprise QA Engineering'].map(s => (
                <li>
                  <span class="info-dot" aria-hidden="true"></span>
                  {s}
                </li>
              ))}
            </ul>
          </div>

          <div class="info-block card info-promise" data-tilt-contact>
            <div class="promise-icon" aria-hidden="true">⚡</div>
            <h3>Our Promise</h3>
            <p>We respond to every serious inquiry within 24 hours. Quality starts with how we communicate, before the contract is signed.</p>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
/* 3D bg */
.has-3d { position: relative; overflow: hidden; }
.rel { position: relative; z-index: 2; }
.section-3d-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    to bottom,
    var(--clr-bg) 0%,
    rgba(2, 9, 24, 0.82) 30%,
    rgba(2, 9, 24, 0.82) 70%,
    var(--clr-bg) 100%
  );
}

.page-hero { padding-top: 10rem; padding-bottom: 5rem; }
.page-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,200,255,0.07), transparent),
    linear-gradient(var(--clr-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--clr-border) 1px, transparent 1px);
  background-size: auto, 60px 60px, 60px 60px;
  mask-image: linear-gradient(to bottom, black 60%, transparent);
}

/* Heading */
.contact-hero-heading {
  font-family: var(--font-heading);
  font-size: clamp(2.4rem, 5.5vw, 4.5rem);
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  margin-top: 1rem;
  margin-bottom: 0;
}

.page-sub { font-size: clamp(1rem, 2vw, 1.15rem); color: var(--clr-muted); max-width: 560px; line-height: 1.8; margin-top: 1.5rem; }

.contact-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: start; max-width: 480px; }

/* Info Sidebar */
.contact-info { display: flex; flex-direction: column; gap: 1rem; }
.info-block {
  padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;
  transform-style: preserve-3d;
  transition: transform 0.4s var(--ease), box-shadow 0.3s var(--ease);
}
.info-block:hover {
  transform: perspective(800px) rotateX(-2deg) rotateY(3deg) translateY(-4px) !important;
  box-shadow: 0 25px 50px rgba(0, 200, 255, 0.1);
}
.info-block h3 { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--clr-muted); }
.info-link { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; color: var(--clr-text); transition: color 0.2s; }
.info-link:hover { color: var(--clr-accent); }
.upwork-link { color: #6fda44; }
.upwork-link:hover { color: #6fda44; opacity: 0.8; }
.info-services { display: flex; flex-direction: column; gap: 0.6rem; }
.info-services li { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; color: var(--clr-muted); }
.info-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--clr-accent); flex-shrink: 0; }
.info-promise { background: var(--clr-accent-dim); border-color: rgba(0,200,255,0.2); }
.promise-icon { font-size: 1.5rem; }
.info-promise h3 { color: var(--clr-accent); }
.info-promise p { font-size: 0.875rem; color: var(--clr-muted); line-height: 1.7; }

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
}
@media (max-width: 560px) {
  }
</style>

<script>
  // 3D tilt for contact cards
  document.querySelectorAll('[data-tilt-contact]').forEach((card) => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateY = ((x - centerX) / centerX) * 6;
      const rotateX = -((y - centerY) / centerY) * 4;
      el.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
    });
    el.addEventListener('mouseleave', () => { el.style.transform = ''; });
  });
</script>