---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import ThreeScene from '../components/ThreeScene.tsx';
import ParticleField from '../components/ParticleField.tsx';
import GridPlane from '../components/GridPlane.tsx';
import WireframeGlobe from '../components/WireframeGlobe.tsx';
import { services } from '../data/services';

const process = [
  { step: '01', title: 'Discovery and Audit', desc: 'We analyze your current QA setup, identify gaps, and map out an AI-enhanced strategy tailored to your stack and goals.' },
  { step: '02', title: 'Strategy and Design', desc: 'We architect the right testing framework, selecting tools, automation layers, and AI components for your specific use case.' },
  { step: '03', title: 'Build and Integrate', desc: 'We implement automated test suites, CI/CD integration, and AI-powered analysis, embedded directly into your workflow.' },
  { step: '04', title: 'Monitor and Optimize', desc: 'Continuous monitoring, intelligent reporting, and iterative improvement to keep your quality standards rising over time.' },
];

const toolCategories = [
  {
    category: 'Web and UI Automation',
    tools: ['Playwright', 'Selenium', 'Cypress', 'WebDriverIO', 'Puppeteer', 'Nightwatch.js', 'TestCafe'],
  },
  {
    category: 'Mobile Testing',
    tools: ['Appium', 'Espresso', 'XCUITest', 'Detox', 'Calabash', 'Selendroid', 'Kobiton'],
  },
  {
    category: 'API Testing',
    tools: ['Postman', 'SoapUI', 'RestAssured', 'Insomnia', 'Karate DSL', 'Newman', 'Bruno', 'Hoppscotch'],
  },
  {
    category: 'Unit Testing',
    tools: ['JUnit', 'TestNG', 'Pytest', 'Jest', 'Vitest', 'NUnit', 'Mocha', 'Jasmine'],
  },
  {
    category: 'Performance and Load',
    tools: ['Apache JMeter', 'Gatling', 'Locust', 'k6', 'BlazeMeter', 'Artillery'],
  },
  {
    category: 'Codeless and AI Platforms',
    tools: ['testRigor', 'Katalon Platform', 'Mabl', 'Tosca'],
  },
  {
    category: 'Agile and Software Development',
    tools: ['Jira', 'Linear'],
  },
  {
    category: 'Collaborative and Visual Workspace',
    tools: ['Trello', 'Monday.com', 'Asana', 'ClickUp', 'Notion'],
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Qignite Services — AI QA and Testing Solutions',
  url: 'https://qignite.com/services',
  description: 'Explore Qignite\'s AI-powered QA services including automated testing, healthcare QA, and enterprise quality engineering.',
  mainEntity: services.map(s => ({
    '@type': 'Service',
    name: s.title,
    description: s.description,
    provider: { '@type': 'Organization', name: 'Qignite' },
  })),
};
---

<Layout
  title="Qignite Services — AI QA Automation, Healthcare Testing and Enterprise Solutions"
  description="Explore Qignite's AI-powered services: intelligent test automation, healthcare platform QA, AI customer support, and enterprise QA engineering. Built for scale."
  keywords="AI test automation services, healthcare QA services, enterprise QA, automated testing Pakistan, QA engineering services, AI customer support solutions"
  structuredData={pageSchema}
>

  <!-- PAGE HERO -->
  <section class="page-hero section has-3d" aria-labelledby="services-heading">
    <ThreeScene client:visible />
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="container rel">
      <span class="section-tag reveal-3d-scale" style="transition-delay:0s">Services</span>
      <h1 class="services-hero-heading reveal-3d" id="services-heading" style="transition-delay:0.1s">
        Intelligent QA <span class="text-accent">for Every Layer</span>
      </h1>
      <p class="page-sub reveal-3d" style="transition-delay:0.2s">
        From AI-powered automation to specialized healthcare testing, Qignite provides end-to-end quality engineering solutions that scale with your product.
      </p>
    </div>
  </section>

  <!-- WHAT WE OFFER -->
  <section class="section has-3d parallax-section" aria-labelledby="our-services-heading" data-parallax="0.04">
    <ParticleField client:visible count={150} opacity={0.35} />
    <div class="section-3d-overlay" aria-hidden="true"></div>
    <div class="container rel">
      <div class="section-header centered reveal-3d" style="transition-delay:0s">
        <span class="section-tag">What We Offer</span>
        <h2 class="display-md" id="our-services-heading">
          Built for <span class="text-accent">Real-World Production</span>
        </h2>
        <p class="text-muted" style="margin-top:1rem; font-size:1rem; line-height:1.75; max-width:560px;">
          Every Qignite service is designed to slot into your existing workflow and deliver measurable quality improvements from day one.
        </p>
      </div>
      <div class="services-grid">
        {services.map((s, i) => <ServiceCard service={s} index={i} showLearnMore={false} />)}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section process-section has-3d parallax-section" aria-labelledby="process-heading" data-parallax="0.03">
    <GridPlane client:visible opacity={0.08} />
    <div class="section-3d-overlay" aria-hidden="true"></div>
    <div class="container rel">
      <div class="section-header reveal-3d-left" style="transition-delay:0s">
        <span class="section-tag">Process</span>
        <h2 class="display-md" id="process-heading">
          How We <span class="text-accent">Work</span>
        </h2>
        <p class="text-muted" style="margin-top:1rem; font-size:1rem; line-height:1.75; max-width:520px;">
          A structured, transparent approach from first conversation to continuous quality monitoring.
        </p>
      </div>
      <div class="process-steps">
        {process.map((p, i) => (
          <div class="process-step reveal-3d-left" style={`transition-delay:${i*0.12}s`}>
            <div class="process-step-num" aria-hidden="true">{p.step}</div>
            <div class="process-step-content">
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOOLS WE MASTER -->
  <section class="section tech-section has-3d parallax-section" aria-labelledby="tech-heading" data-parallax="0.05">
    <ParticleField client:visible color="#3B6FFF" color2="#00C8FF" count={100} opacity={0.3} speed={0.6} />
    <div class="section-3d-overlay" aria-hidden="true"></div>
    <div class="container rel">
      <div class="section-header centered reveal-3d" style="transition-delay:0s">
        <span class="section-tag">Technology</span>
        <h2 class="display-md" id="tech-heading">
          Tools We <span class="text-accent">Master</span>
        </h2>
      </div>
      <div class="tool-categories">
        {toolCategories.map((cat, ci) => (
          <div class="tool-category reveal-3d" style={`transition-delay:${ci * 0.08}s`}>
            <h3 class="tool-category-title">{cat.category}</h3>
            <div class="tool-badges">
              {cat.tools.map(tool => (
                <span class="tech-badge card float-badge">{tool}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section industries-section has-3d parallax-section" aria-labelledby="industries-heading" data-parallax="0.03">
    <WireframeGlobe client:visible size={12} opacity={0.06} />
    <div class="section-3d-overlay" aria-hidden="true"></div>
    <div class="container rel">
      <div class="industries-inner">
        <div class="reveal-3d-left" style="transition-delay:0s">
          <span class="section-tag">Industries</span>
          <h2 class="display-md" id="industries-heading">Who We Serve</h2>
          <p class="text-muted" style="margin-top:1rem; line-height:1.8; max-width:480px;">
            Qignite serves healthcare organizations, digital pathology platforms, and enterprise software companies operating in international markets.
          </p>
        </div>
        <div class="industry-cards">
          {[
            { icon: '🏥', title: 'Healthcare Systems', desc: 'EHRs, patient portals, clinical decision tools' },
            { icon: '🔬', title: 'Digital Pathology', desc: 'AI-assisted diagnostics, imaging platforms' },
            { icon: '🏢', title: 'Enterprise Software', desc: 'SaaS platforms, internal tools, APIs' },
            { icon: '🌐', title: 'International Markets', desc: 'Multi-region, compliance-aware deployments' },
          ].map((ind, i) => (
            <div class="industry-item card reveal-3d" style={`transition-delay:${i*0.1}s`}>
              <span class="industry-icon" aria-hidden="true">{ind.icon}</span>
              <div>
                <h3>{ind.title}</h3>
                <p>{ind.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to Transform Your QA Process?"
    sub="Let's build AI-powered quality engineering that grows with your product and your team."
  />
</Layout>

<style>
/* 3D bg */
.has-3d { position: relative; overflow: hidden; }
.rel { position: relative; z-index: 2; }
.section-3d-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    to bottom,
    var(--clr-bg) 0%,
    rgba(2, 9, 24, 0.82) 30%,
    rgba(2, 9, 24, 0.82) 70%,
    var(--clr-bg) 100%
  );
}

/* Page hero */
.page-hero { padding-top: 10rem; padding-bottom: 5rem; }
.page-hero-bg {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,200,255,0.07), transparent),
    linear-gradient(var(--clr-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--clr-border) 1px, transparent 1px);
  background-size: auto, 60px 60px, 60px 60px;
  mask-image: linear-gradient(to bottom, black 60%, transparent);
}

/* Refined heading */
.services-hero-heading {
  font-family: var(--font-heading);
  font-size: clamp(2.4rem, 5.5vw, 4.5rem);
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  max-width: 720px;
  margin-top: 1rem;
  margin-bottom: 0;
}

.page-sub { font-size: clamp(1rem, 2vw, 1.15rem); color: var(--clr-muted); max-width: 580px; line-height: 1.8; margin-top: 1.5rem; }
.services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }

/* Process */
.process-section { background: var(--clr-bg-2); border-top: 1px solid var(--clr-border); border-bottom: 1px solid var(--clr-border); }
.process-steps { display: flex; flex-direction: column; gap: 0; max-width: 750px; }
.process-step {
  display: grid; grid-template-columns: 80px 1fr; gap: 2rem; align-items: start;
  padding: 2rem 0; border-bottom: 1px solid var(--clr-border);
  transition: transform 0.3s var(--ease);
}
.process-step:hover { transform: translateX(8px); }
.process-step:last-child { border-bottom: none; }
.process-step-num { font-family: var(--font-heading); font-size: 3rem; font-weight: 800; color: var(--clr-accent); opacity: 0.3; line-height: 1; }
.process-step-content h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; }
.process-step-content p { color: var(--clr-muted); line-height: 1.75; font-size: 0.95rem; }

/* Tools */
.tool-categories { display: flex; flex-direction: column; gap: 2.5rem; }
.tool-category-title {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--clr-accent);
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--clr-border);
}
.tool-badges { display: flex; flex-wrap: wrap; gap: 0.6rem; }
.tech-badge {
  padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 500;
  color: var(--clr-muted); border-radius: 100px; cursor: default;
  transition: color 0.2s, border-color 0.2s, transform 0.3s;
}
.tech-badge:hover {
  color: var(--clr-accent); border-color: var(--clr-accent);
  transform: translateY(-2px) !important;
}

/* Industries */
.industries-section { background: var(--clr-bg-2); border-top: 1px solid var(--clr-border); border-bottom: 1px solid var(--clr-border); }
.industries-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.industry-cards { display: flex; flex-direction: column; gap: 1rem; }
.industry-item {
  display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem 1.5rem;
  transition: transform 0.3s var(--ease);
}
.industry-item:hover { transform: translateX(8px); }
.industry-icon { font-size: 1.75rem; flex-shrink: 0; }
.industry-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
.industry-item p { font-size: 0.85rem; color: var(--clr-muted); }

@media (max-width: 900px) {
  .services-grid { grid-template-columns: 1fr; }
  .industries-inner { grid-template-columns: 1fr; gap: 3rem; }
  .services-hero-heading { font-size: clamp(2rem, 7vw, 3rem); }
}
</style>