---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import ThreeScene from '../components/ThreeScene.tsx';

const values = [
  { icon: '⚡', title: 'Precision First', desc: 'Every bug caught, every edge case explored. We don\'t ship guesses.' },
  { icon: '🤖', title: 'AI-Native Thinking', desc: 'We don\'t bolt AI on. We design quality workflows with intelligence at the core.' },
  { icon: '🏥', title: 'Healthcare Expertise', desc: 'Specialized knowledge of compliance, safety-critical systems, and digital pathology.' },
  { icon: '🌐', title: 'Global Standards', desc: 'Delivering QA solutions for international markets with enterprise-grade reliability.' },
  { icon: '🔄', title: 'Continuous Improvement', desc: 'Quality isn\'t a milestone — it\'s a culture we build into every process.' },
  { icon: '🤝', title: 'Transparent Partnership', desc: 'We work alongside your team, not in a black box. Full visibility. Real accountability.' },
];

const milestones = [
  { year: '2023', title: 'Founded', desc: 'Qignite was established with a clear mission: bring AI to QA engineering.' },
  { year: '2023', title: 'First Healthcare Client', desc: 'Delivered QA services for an international digital pathology platform.' },
  { year: '2024', title: 'AI Support Launch', desc: 'Launched our AI-assisted customer support offering for enterprise clients.' },
  { year: '2024', title: 'International Expansion', desc: 'Extended services to 10+ global markets in healthcare and enterprise.' },
  { year: '2025', title: 'GDG Community', desc: 'Showcased AI-powered QA workflows at GDG Islamia College Peshawar.' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Qignite — AI-Driven QA Company',
  url: 'https://qignite.com/about',
  description: 'Learn about Qignite\'s mission, values, and journey building AI-powered quality assurance solutions.',
};
---

<Layout
  title="About Qignite — Our Mission, Vision & Values"
  description="Qignite is an AI-driven software quality assurance company modernizing testing and support workflows across healthcare and enterprise platforms worldwide. Learn our story."
  keywords="about Qignite, AI QA company, software quality assurance company, healthcare QA experts, QA engineering team Pakistan"
  structuredData={pageSchema}
>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero section has-video" aria-labelledby="about-heading">
    <div class="section-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/videos/about-bg.mp4" type="video/mp4" />
      </video>
      <div class="section-video-overlay"></div>
    </div>
    <!-- Three.js particles in hero -->
    <ThreeScene client:visible />
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="container rel">
      <span class="section-tag reveal-3d-scale" style="transition-delay:0s">Company</span>
      <h1 class="about-hero-heading reveal-3d" id="about-heading" style="transition-delay:0.1s">
        We Build Software <span class="text-accent">Quality</span> at Scale
      </h1>
      <p class="page-hero-sub reveal-3d" style="transition-delay:0.2s">
        Qignite is an AI-driven software quality assurance company focused on modernizing testing and support workflows across healthcare and enterprise platforms operating in international markets.
      </p>
    </div>
  </section>

  <!-- ═══ MISSION / VISION ═══ -->
  <section class="section mv-section has-video parallax-section" aria-labelledby="mission-heading" data-parallax="0.04">
    <div class="section-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/videos/hero-bg.mp4" type="video/mp4" />
      </video>
      <div class="section-video-overlay"></div>
    </div>
    <div class="container rel">
      <div class="mv-grid">
        <div class="mv-card card reveal-3d-left" style="transition-delay:0s" data-tilt-about>
          <span class="mv-icon">🎯</span>
          <h2 id="mission-heading">Our Mission</h2>
          <p>To deliver intelligent, reliable quality assurance solutions that help healthcare and enterprise organizations ship software with confidence — combining proven QA practices with cutting-edge AI automation.</p>
        </div>
        <div class="mv-card card reveal-3d-left" style="transition-delay:0.15s" data-tilt-about>
          <span class="mv-icon">🔭</span>
          <h2>Our Vision</h2>
          <p>A world where AI-powered quality engineering is accessible to every software team — where bugs are caught before they reach users, and software reliability is the default, not the exception.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT WE SPECIALIZE IN ═══ -->
  <section class="section what-section has-video parallax-section" aria-labelledby="what-heading" data-parallax="0.03">
    <div class="section-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/videos/about-bg.mp4" type="video/mp4" />
      </video>
      <div class="section-video-overlay"></div>
    </div>
    <div class="container rel">
      <div class="section-header reveal-3d-left" style="transition-delay:0s">
        <span class="section-tag">Expertise</span>
        <h2 class="display-md" id="what-heading">What We <span class="text-accent">Specialize In</span></h2>
      </div>
      <div class="what-grid">
        <div class="what-item reveal-3d" style="transition-delay:0s">
          <h3>AI-Powered Testing Workflows</h3>
          <p>We design and implement intelligent automation strategies that use machine learning to detect patterns, predict failures, and self-heal test scripts — dramatically reducing maintenance overhead.</p>
        </div>
        <div class="what-item reveal-3d" style="transition-delay:0.1s">
          <h3>Healthcare & Digital Pathology</h3>
          <p>Specialized QA for healthcare systems, EHRs, and digital pathology platforms. We understand the compliance requirements and safety implications unique to healthcare software.</p>
        </div>
        <div class="what-item reveal-3d" style="transition-delay:0.2s">
          <h3>Enterprise QA Engineering</h3>
          <p>End-to-end quality engineering services — from strategy to execution. We embed QA into your CI/CD pipeline, ensuring quality at every stage of development.</p>
        </div>
        <div class="what-item reveal-3d" style="transition-delay:0.3s">
          <h3>AI Customer Support</h3>
          <p>Intelligent support agents built on LLMs that resolve issues faster, reduce ticket volume, and provide consistent accurate answers — available around the clock for your users.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VALUES ═══ -->
  <section class="section values-section has-video parallax-section" aria-labelledby="values-heading" data-parallax="0.05">
    <div class="section-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/videos/services-bg.mp4" type="video/mp4" />
      </video>
      <div class="section-video-overlay"></div>
    </div>
    <div class="container rel">
      <div class="section-header centered reveal-3d" style="transition-delay:0s">
        <span class="section-tag">Culture</span>
        <h2 class="display-md" id="values-heading">What We <span class="text-accent">Stand For</span></h2>
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <div class="value-card card reveal-3d" style={`transition-delay:${i*0.1}s`} data-tilt-about>
            <span class="value-icon" aria-hidden="true">{v.icon}</span>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="section timeline-section has-video parallax-section" aria-labelledby="journey-heading" data-parallax="0.03">
    <div class="section-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/videos/cta-bg.mp4" type="video/mp4" />
      </video>
      <div class="section-video-overlay"></div>
    </div>
    <div class="container rel">
      <div class="section-header reveal-3d-left" style="transition-delay:0s">
        <span class="section-tag">Journey</span>
        <h2 class="display-md" id="journey-heading">Our <span class="text-accent">Story So Far</span></h2>
      </div>
      <div class="timeline">
        {milestones.map((m, i) => (
          <div class="timeline-item reveal-3d-left" style={`transition-delay:${i*0.12}s`}>
            <div class="timeline-year">{m.year}</div>
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content card">
              <h3>{m.title}</h3>
              <p>{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
/* ── Shared video background pattern ── */
.has-video { position: relative; overflow: hidden; }
.rel { position: relative; z-index: 2; }

.section-video-bg {
  position: absolute; inset: 0; z-index: 0;
}
.section-video-bg video {
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0.55;          /* subtle — just enough to feel alive */
}
.section-video-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(
    to bottom,
    var(--clr-bg) 0%,
    rgba(2, 9, 24, 0.75) 40%,
    rgba(2, 9, 24, 0.75) 60%,
    var(--clr-bg) 100%
  );
}

/* ── Page Hero ── */
.page-hero { padding-top: 10rem; padding-bottom: 5rem; }
.page-hero-bg {
  position: absolute; inset: 0; z-index: 1;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,200,255,0.07), transparent),
    linear-gradient(var(--clr-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--clr-border) 1px, transparent 1px);
  background-size: auto, 60px 60px, 60px 60px;
  mask-image: linear-gradient(to bottom, black 60%, transparent);
  pointer-events: none;
}

.about-hero-heading {
  font-family: var(--font-heading);
  font-size: clamp(2.4rem, 5.5vw, 4.5rem);
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  max-width: 700px;
  margin-top: 1rem;
  margin-bottom: 0;
}
.page-hero-sub { font-size: clamp(1rem, 2vw, 1.2rem); color: var(--clr-muted); max-width: 620px; line-height: 1.8; margin-top: 1.5rem; }

/* ── Mission / Vision ── */
.mv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.mv-card {
  padding: 2.5rem; display: flex; flex-direction: column; gap: 1rem;
  transform-style: preserve-3d;
  transition: transform 0.4s var(--ease), box-shadow 0.3s var(--ease);
}
.mv-card:hover {
  transform: perspective(800px) rotateX(-2deg) rotateY(3deg) translateY(-4px) !important;
  box-shadow: 0 25px 50px rgba(0, 200, 255, 0.1);
}
.mv-icon { font-size: 2rem; }
.mv-card h2 { font-size: 1.5rem; font-weight: 700; color: var(--clr-accent); }
.mv-card p { color: var(--clr-muted); line-height: 1.8; }

/* ── What we specialize in ── */
.what-section { background: var(--clr-bg-2); border-top: 1px solid var(--clr-border); border-bottom: 1px solid var(--clr-border); }
.what-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
.what-item {
  padding: 2rem; border-left: 2px solid var(--clr-border);
  transition: border-color 0.3s, transform 0.3s var(--ease);
}
.what-item:hover {
  border-left-color: var(--clr-accent);
  transform: translateX(8px);
}
.what-item h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--clr-text); }
.what-item p { color: var(--clr-muted); line-height: 1.75; font-size: 0.95rem; }

/* ── Values ── */
.values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.value-card {
  padding: 2rem; display: flex; flex-direction: column; gap: 0.75rem;
  transform-style: preserve-3d;
  transition: transform 0.4s var(--ease), box-shadow 0.3s var(--ease);
}
.value-card:hover {
  transform: perspective(800px) rotateX(-2deg) rotateY(3deg) translateY(-4px) !important;
  box-shadow: 0 25px 50px rgba(0, 200, 255, 0.1);
}
.value-icon { font-size: 1.75rem; }
.value-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--clr-text); }
.value-card p { font-size: 0.9rem; color: var(--clr-muted); line-height: 1.7; }

/* ── Timeline ── */
.timeline { display: flex; flex-direction: column; gap: 0; max-width: 700px; padding-left: 2rem; border-left: 1px solid var(--clr-border); }
.timeline-item { display: grid; grid-template-columns: 80px 1fr; gap: 1.5rem; align-items: start; padding-bottom: 2.5rem; position: relative; }
.timeline-item::before { content: ''; position: absolute; left: -5px; top: 6px; width: 9px; height: 9px; border-radius: 50%; background: var(--clr-accent); box-shadow: 0 0 12px var(--clr-glow); }
.timeline-year { font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: var(--clr-accent); padding-top: 0.25rem; text-align: right; }
.timeline-dot { display: none; }
.timeline-content {
  padding: 1.25rem 1.5rem;
  transition: transform 0.3s var(--ease), box-shadow 0.3s;
}
.timeline-content:hover {
  transform: translateX(8px);
  box-shadow: 0 10px 30px rgba(0, 200, 255, 0.08);
}
.timeline-content h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem; }
.timeline-content p { font-size: 0.9rem; color: var(--clr-muted); line-height: 1.7; }

/* ── Responsive ── */
@media (max-width: 768px) {
  .mv-grid, .what-grid, .values-grid { grid-template-columns: 1fr; }
  .values-grid { grid-template-columns: 1fr 1fr; }
  .about-hero-heading { font-size: clamp(2rem, 7vw, 3rem); }
}
@media (max-width: 480px) { .values-grid { grid-template-columns: 1fr; } }
</style>

<script>
  // 3D tilt for about page cards
  document.querySelectorAll('[data-tilt-about]').forEach((card) => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateY = ((x - centerX) / centerX) * 6;
      const rotateX = -((y - centerY) / centerY) * 4;
      el.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
    });
    el.addEventListener('mouseleave', () => { el.style.transform = ''; });
  });
</script>