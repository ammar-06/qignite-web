---
/* No props needed — this is a global loading skeleton */
---

<div class="skeleton-loader" id="skeleton-loader" aria-hidden="true">
  <div class="skeleton-inner">
    <!-- Nav bar skeleton -->
    <div class="skel-nav">
      <div class="skel-block skel-logo"></div>
      <div class="skel-nav-links">
        <div class="skel-block skel-navlink"></div>
        <div class="skel-block skel-navlink"></div>
        <div class="skel-block skel-navlink"></div>
        <div class="skel-block skel-navlink"></div>
        <div class="skel-block skel-navlink"></div>
      </div>
    </div>

    <!-- Hero skeleton -->
    <div class="skel-hero">
      <div class="skel-block skel-tag"></div>
      <div class="skel-block skel-heading"></div>
      <div class="skel-block skel-heading skel-heading-2"></div>
      <div class="skel-block skel-subtext"></div>
      <div class="skel-block skel-subtext skel-subtext-2"></div>
      <div class="skel-ctas">
        <div class="skel-block skel-btn"></div>
        <div class="skel-block skel-btn skel-btn-outline"></div>
      </div>
    </div>

    <!-- Floating particles placeholder -->
    <div class="skel-particles">
      <div class="skel-dot" style="top:15%;left:20%;animation-delay:0s"></div>
      <div class="skel-dot" style="top:30%;left:70%;animation-delay:0.3s"></div>
      <div class="skel-dot" style="top:60%;left:40%;animation-delay:0.6s"></div>
      <div class="skel-dot" style="top:45%;left:85%;animation-delay:0.9s"></div>
      <div class="skel-dot" style="top:75%;left:15%;animation-delay:1.2s"></div>
      <div class="skel-dot" style="top:20%;left:55%;animation-delay:0.4s"></div>
      <div class="skel-dot" style="top:80%;left:65%;animation-delay:0.7s"></div>
    </div>
  </div>
</div>

<style>
.skeleton-loader {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #020918;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  transition: opacity 0.6s ease, visibility 0.6s ease;
  overflow: hidden;
}
.skeleton-loader.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.skeleton-inner {
  width: 100%;
  max-width: 1200px;
  padding: 0 2.5rem;
  position: relative;
  min-height: 100vh;
}

/* Shimmer effect */
.skel-block {
  background: linear-gradient(
    90deg,
    rgba(0, 200, 255, 0.03) 0%,
    rgba(0, 200, 255, 0.08) 40%,
    rgba(0, 200, 255, 0.03) 80%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s ease-in-out infinite;
  border-radius: 8px;
  position: relative;
  overflow: hidden;
}

.skel-block::after {
  content: '';
  position: absolute;
  inset: 0;
  border: 1px solid rgba(0, 200, 255, 0.06);
  border-radius: inherit;
}

/* Nav */
.skel-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 0;
}
.skel-logo { width: 120px; height: 36px; }
.skel-nav-links { display: flex; gap: 1rem; }
.skel-navlink { width: 60px; height: 14px; border-radius: 100px; }

/* Hero */
.skel-hero {
  padding-top: 8rem;
  max-width: 700px;
}
.skel-tag { width: 100px; height: 28px; border-radius: 100px; margin-bottom: 2rem; }
.skel-heading { width: 90%; height: 60px; margin-bottom: 0.75rem; }
.skel-heading-2 { width: 60%; height: 60px; margin-bottom: 2rem; }
.skel-subtext { width: 80%; height: 16px; margin-bottom: 0.5rem; }
.skel-subtext-2 { width: 55%; height: 16px; margin-bottom: 2.5rem; }
.skel-ctas { display: flex; gap: 1rem; }
.skel-btn { width: 160px; height: 48px; border-radius: 100px; }
.skel-btn-outline {
  width: 140px; height: 48px; border-radius: 100px;
  background: transparent;
  border: 1px solid rgba(0, 200, 255, 0.1);
}

/* Floating dots */
.skel-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.skel-dot {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.3);
  animation: skelFloat 3s ease-in-out infinite;
  box-shadow: 0 0 8px rgba(0, 200, 255, 0.3);
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes skelFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
  50% { transform: translateY(-15px) scale(1.5); opacity: 0.8; }
}

@media (max-width: 768px) {
  .skel-nav-links { display: none; }
  .skel-heading { height: 40px; }
  .skel-heading-2 { height: 40px; }
  .skel-hero { padding-top: 6rem; }
}
</style>
