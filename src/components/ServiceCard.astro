---
import type { Service } from '../data/services';

interface Props {
  service: Service;
  index?: number;
  showLearnMore?: boolean;
}
const { service, index = 0, showLearnMore = true } = Astro.props;

const icons: Record<string, string> = {
  brain: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>`,
  'heart-pulse': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l1.5-3 2 4.5 1.5-2.5 1.5 2H20"/></svg>`,
  bot: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>`,
  layers: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
};
---

<article
  class="service-card card reveal"
  id={service.id}
  style={`transition-delay: ${index * 0.1}s`}
  itemscope
  itemtype="https://schema.org/Service"
>
  <div class="sc-tag">{service.tag}</div>

  <div class="sc-icon" aria-hidden="true">
    <Fragment set:html={icons[service.icon] ?? icons.brain} />
  </div>

  <h3 class="sc-title" itemprop="name">{service.title}</h3>
  <p class="sc-desc" itemprop="description">{service.description}</p>

  <ul class="sc-features" aria-label={`Features of ${service.title}`}>
    {service.features.map((f: string) => (
      <li class="sc-feature">
        <span class="sc-dot" aria-hidden="true"></span>
        {f}
      </li>
    ))}
  </ul>

  {showLearnMore && (
    <a href={`/services#${service.id}`} class="sc-link" aria-label={`Learn more about ${service.title}`}>
      Learn More
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  )}
</article>

<style>
.service-card {
  display: flex; flex-direction: column; gap: 0;
  padding: 2rem; position: relative; overflow: hidden;
}
.service-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--clr-accent), transparent);
  opacity: 0; transition: opacity 0.3s;
}
.service-card:hover::before { opacity: 1; }

.sc-tag {
  font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--clr-accent); margin-bottom: 1.25rem;
}
.sc-icon {
  width: 52px; height: 52px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-sm);
  background: var(--clr-accent-dim); border: 1px solid var(--clr-border);
  color: var(--clr-accent); margin-bottom: 1.25rem;
  transition: background 0.3s, box-shadow 0.3s;
}
.service-card:hover .sc-icon { background: rgba(0,200,255,0.2); box-shadow: 0 0 20px var(--clr-glow); }
.sc-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--clr-text); }
.sc-desc { font-size: 0.9rem; color: var(--clr-muted); line-height: 1.75; margin-bottom: 1.5rem; }
.sc-features { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; flex: 1; }
.sc-feature { display: flex; align-items: center; gap: 0.625rem; font-size: 0.875rem; color: var(--clr-muted); }
.sc-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--clr-accent); flex-shrink: 0; }
.sc-link {
  display: inline-flex; align-items: center; gap: 0.4rem;
  font-size: 0.875rem; font-weight: 600; color: var(--clr-accent);
  margin-top: auto; transition: gap 0.2s;
}
.sc-link:hover { gap: 0.7rem; }
</style>